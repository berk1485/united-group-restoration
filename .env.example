# United Group Restoration - Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Admin credentials
ADMIN_EMAIL=admin@unitedgrouprestoration.com
ADMIN_PASSWORD=changeme123

# Claude AI (for chat support)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Email (nodemailer - use Gmail or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="United Group Restoration <noreply@unitedgrouprestoration.com>"
LEAD_NOTIFY_EMAIL=admin@unitedgrouprestoration.com

# SMS (Twilio - optional, for booking reminders)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# Upload limits
MAX_UPLOAD_SIZE_MB=20
MAX_UPLOADS_PER_LEAD=10

# Session secret (generate a random string)
SESSION_SECRET=change-this-to-a-random-secret-string
