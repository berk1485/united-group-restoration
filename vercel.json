{
  "version": 2,
  "buildCommand": "npm run build || echo 'No build needed'",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index-redesigned.html"
    },
    {
      "source": "/:path*",
      "destination": "/index-redesigned.html"
    }
  ]
}
