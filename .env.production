# United Group Inc. — Production Environment Template
# Copy this file to `.env` on your production host. Never commit the real .env.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Only set USE_HTTPS=true if you are terminating TLS in this Node process
# (e.g. running on a bare VPS without a reverse proxy). Most managed hosts
# (Render, Vercel, Fly, Heroku, Railway, DigitalOcean App Platform) handle
# TLS at the edge — leave USE_HTTPS unset there.
USE_HTTPS=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ─── Public site config ──────────────────────────────────────────────────────
PUBLIC_URL=https://www.unitedgroupinc.com
COMPANY_NAME="United Group Inc."
COMPANY_PHONE="856-254-8367"
COMPANY_ADDRESS="1000 Delsea Dr Ste I-4, Westville NJ 08093"

# ─── Admin credentials ───────────────────────────────────────────────────────
# CHANGE BOTH BEFORE FIRST DEPLOY.
ADMIN_EMAIL=admin@unitedgroupinc.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Claude AI (chat support) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ─── Email (transactional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@unitedgroupinc.com
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
SMTP_FROM="United Group Inc. <info@unitedgroupinc.com>"
LEAD_NOTIFY_EMAIL=leads@unitedgroupinc.com

# ─── SMS (Twilio — optional) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Upload limits ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
MAX_UPLOADS_PER_LEAD=10

# ─── Session ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX
